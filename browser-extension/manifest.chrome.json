{
  "manifest_version": 3,
  "name": "cosmos by polarity lab",
  "short_name": "cosmos",
  "version": "0.1.7",
  "description": "The browser surface of Cosmos MCP. Sends the pages you actually read into your Cosmos graph. Local filtering, no analytics.",
  "permissions": [
    "history",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://cosmos.polarity-lab.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cosmos",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
