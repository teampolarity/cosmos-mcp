{
  "_doc": "Canonical browser-history noise lists. Source of truth: this file, at cosmos-mcp/src/sources/browser/filter-rules.json. The browser extension at cosmos-mcp/browser-extension/ copies it in via browser-extension/scripts/sync-filter-rules.sh. Update here first, then re-run that sync script before rebuilding the extension. The server-side endpoint at cosmos-fork/functions/api/me/connectors/browser/visits.js also runs URL normalization (normalize_url_rules below) so dedup-on-replay catches the same content visited from different Google account contexts.",
  "noise_root_hosts": [
    "mail.google.com",
    "calendar.google.com",
    "drive.google.com",
    "docs.google.com",
    "accounts.google.com",
    "chatgpt.com",
    "claude.ai",
    "linkedin.com",
    "x.com",
    "twitter.com",
    "instagram.com",
    "facebook.com",
    "messenger.com",
    "slack.com",
    "discord.com",
    "notion.so",
    "figma.com",
    "dash.cloudflare.com",
    "console.anthropic.com",
    "platform.openai.com",
    "vercel.com",
    "render.com",
    "supabase.com",
    "stripe.com",
    "appleid.apple.com",
    "icloud.com",
    "amazon.com",
    "amazon.co.uk"
  ],
  "drop_hosts": [
    "polarity-lab.com",
    "www.polarity-lab.com",
    "cosmos.polarity-lab.com",
    "blueno.polarity-lab.com",
    "api.blueno.polarity-lab.com",
    "therapists.blueno.polarity-lab.com",
    "mcp.polarity-lab.com",
    "app.polarity-lab.com",
    "wax-feed.com",
    "www.wax-feed.com",
    "shadrackannor.com",
    "averydistantperspective.com",
    "percent2agi.com",
    "localhost",
    "127.0.0.1",
    "0.0.0.0"
  ],
  "noise_path_prefixes": [
    "/feed",
    "/home",
    "/explore",
    "/notifications",
    "/notification",
    "/messages",
    "/settings",
    "/account",
    "/login",
    "/logout",
    "/signin",
    "/signup",
    "/auth/",
    "/oauth/",
    "/callback",
    "/inbox"
  ],
  "noise_path_patterns": [
    "^/drive/u/\\d+/?$",
    "^/drive/u/\\d+/home$",
    "^/drive/u/\\d+/my-drive$",
    "^/drive/u/\\d+/shared-with-me$",
    "^/drive/u/\\d+/recent$",
    "^/drive/u/\\d+/starred$",
    "^/drive/u/\\d+/trash$",
    "^/drive/u/\\d+/search",
    "^/drive/search",
    "^/drive/?$",
    "^/drive/home$",
    "^/drive/my-drive$",
    "^/search/?$",
    "^/u/\\d+/?$"
  ],
  "noise_title_patterns": [
    "^inbox \\(",
    "^new tab$",
    "^untitled$",
    "^sign in",
    "^log in",
    "^home / x$",
    "^home$",
    "^home - google drive$",
    "^my drive - google drive$",
    "^google drive$",
    "^starred - google drive$",
    "^shared with me - google drive$",
    "^recent - google drive$",
    "^trash - google drive$",
    "^search results - google drive$",
    "^feed \\| ",
    "^loading\\.\\.\\.",
    "^just a moment",
    "^access denied$",
    "^error$",
    "^404 ",
    "^amo review probe$"
  ],
  "min_title_length": 12,
  "normalize_url_rules": {
    "_doc": "Patterns applied at ingest to collapse equivalent URLs into one source_id. The same Google Sheet visited from /u/0/ and /u/2/ should become one node. Patterns are { match: regex, replace: replacement } applied to the full URL.",
    "patterns": [
      { "match": "^(https://docs\\.google\\.com)(?:/u/\\d+)?/(spreadsheets|document|presentation|forms)/d/([^/?#]+).*$", "replace": "$1/$2/d/$3/" },
      { "match": "^(https://drive\\.google\\.com)/(?:u/\\d+/)?file/d/([^/?#]+).*$", "replace": "$1/file/d/$2/view" },
      { "match": "^(https://drive\\.google\\.com)/drive/(?:u/\\d+/)?folders/([^/?#]+).*$", "replace": "$1/drive/folders/$2" }
    ]
  }
}
